{
  "name": "cars-data",
  "type": "module",
  "engineStrict": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "predev": "node check-packages.js",
    "dev": "vite --config ./vite.config.ts --open",
    "dev:check": "vite --config ./vite.config.ts --open -- --use-checker",
    "preview": "vite preview --config ./vite.config.ts",
    "http": "http-server ../data/misc --cors -p 8000",
    "playwright:setup": "playwright install --with-deps",
    "playwright": "playwright test --config=playwright.config.ts",
    "playwright:update": "playwright test --config=playwright.config.ts --update-snapshots",
    "cypress:setup": "concurrently -k \"pnpm run preview\" \"pnpm run http\"",
    "cypress": "start-server-and-test 'pnpm run cypress:setup' \"http://localhost:3000|http://localhost:8000\" 'cypress run'",
    "vitest": "vitest --config vitest.config.ts",
    "audit": "pnpm audit --audit-level high --prod",
    "eslint": "eslint . --config ./eslint.config.js",
    "eslint:fix": "eslint . --config ./eslint.config.js --fix",
    "lint": "biome lint --diagnostic-level=warn .",
    "lint:fix": "biome lint --diagnostic-level=warn --write .",
    "format": "biome format --diagnostic-level=warn .",
    "format:fix": "biome format --diagnostic-level=warn --write .",
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "build": "vite --config ./vite.config.ts build",
    "prepare": "cd .. && husky app/.husky"
  },
  "minimumReleaseAge": 60,
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "chart.js": "^4.5.1",
    "chartjs-chart-treemap": "^3.1.0",
    "i18next": "^26.0.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-router": "^7.14.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cypress": "^15.14.0",
    "eslint": "^9.39.4",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-cypress": "^6.3.1",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.5.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "start-server-and-test": "^3.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-checker": "^0.13.0",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion": "^5.0.1",
      "axios": "^1.15.0",
      "diff": "^8.0.3",
      "lodash": "^4.18.1",
      "minimatch": "^10.2.3",
      "picomatch": "^4.0.4",
      "qs": "^6.14.2",
      "systeminformation": "^5.31.0",
      "undici": "^7.24.0",
      "yauzl": "^3.2.1"
    }
  }
}
