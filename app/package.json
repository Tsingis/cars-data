{
  "name": "cars-data",
  "type": "module",
  "engineStrict": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.17.0+sha512.cca3cea332ad254bb84145f966d19f4879615210346fc92c79a047f23a0d7b3cca3c3792f0076ba1f1831d277efbcf0a9119b31a9a60eca7fb3d6231f331ef72",
  "scripts": {
    "predev": "node check-packages.js",
    "dev": "vite --config ./vite.config.ts --open",
    "dev:check": "vite --config ./vite.config.ts --open -- --use-checker",
    "preview": "vite preview --config ./vite.config.ts",
    "http": "http-server ../data/misc --cors -p 8000",
    "playwright:setup": "playwright install --with-deps",
    "playwright": "playwright test --config=playwright.config.ts",
    "playwright:update": "playwright test --config=playwright.config.ts --update-snapshots",
    "cypress:setup": "concurrently -k \"pnpm run preview\" \"pnpm run http\"",
    "cypress": "start-server-and-test 'pnpm run cypress:setup' \"http://localhost:3000|http://localhost:8000\" 'cypress run'",
    "vitest": "vitest --config vitest.config.ts",
    "audit": "pnpm audit --audit-level high --prod",
    "eslint": "eslint . --config ./eslint.config.js --cache",
    "eslint:fix": "eslint . --config ./eslint.config.js --fix",
    "lint": "biome lint --diagnostic-level=warn .",
    "lint:fix": "biome lint --diagnostic-level=warn --write .",
    "format": "biome format --diagnostic-level=warn .",
    "format:fix": "biome format --diagnostic-level=warn --write .",
    "typecheck": "tsc -p ./tsconfig.json",
    "build": "vite --config ./vite.config.ts build",
    "prepare": "cd .. && husky app/.husky"
  },
  "minimumReleaseAge": 1440,
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.1",
    "@fortawesome/free-solid-svg-icons": "^7.3.1",
    "@fortawesome/react-fontawesome": "^3.5.0",
    "chart.js": "^4.5.1",
    "chartjs-chart-treemap": "^4.2.0",
    "i18next": "^26.3.6",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-i18next": "^17.0.10",
    "react-router": "^8.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitejs/plugin-react": "^6.0.4",
    "concurrently": "^10.0.3",
    "cypress": "^15.19.0",
    "eslint": "^9.39.5",
    "eslint-plugin-cypress": "^6.4.3",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-i18next": "^6.1.5",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-playwright": "^2.10.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.2.0",
    "globals": "^17.7.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "start-server-and-test": "^3.0.11",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vite-plugin-checker": "^0.14.5",
    "vitest": "^4.1.10"
  }
}
