{
  "name": "cars-data",
  "type": "module",
  "engineStrict": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "scripts": {
    "predev": "node check-packages.js",
    "dev": "vite --config ./vite.config.ts --open",
    "dev:check": "vite --config ./vite.config.ts --open -- --use-checker",
    "preview": "vite preview --config ./vite.config.ts",
    "http": "http-server ../data/misc --cors -p 8000",
    "playwright:setup": "playwright install --with-deps",
    "playwright": "playwright test --config=playwright.config.ts",
    "playwright:update": "playwright test --config=playwright.config.ts --update-snapshots",
    "cypress:setup": "concurrently -k \"pnpm run preview\" \"pnpm run http\"",
    "cypress": "start-server-and-test 'pnpm run cypress:setup' \"http://localhost:3000|http://localhost:8000\" 'cypress run'",
    "vitest": "vitest --config vitest.config.ts",
    "audit": "pnpm audit --audit-level high --prod",
    "eslint": "eslint . --config ./eslint.config.js --cache",
    "eslint:fix": "eslint . --config ./eslint.config.js --fix",
    "lint": "biome lint --diagnostic-level=warn .",
    "lint:fix": "biome lint --diagnostic-level=warn --write .",
    "format": "biome format --diagnostic-level=warn .",
    "format:fix": "biome format --diagnostic-level=warn --write .",
    "typecheck": "tsc -p ./tsconfig.json",
    "build": "vite --config ./vite.config.ts build",
    "prepare": "cd .. && husky app/.husky"
  },
  "minimumReleaseAge": 1440,
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.4.0",
    "chart.js": "^4.5.1",
    "chartjs-chart-treemap": "^4.2.0",
    "i18next": "^26.3.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "cypress": "^15.18.1",
    "eslint": "^9.39.5",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-cypress": "^6.4.2",
    "eslint-plugin-i18n-json": "^4.0.1",
    "eslint-plugin-i18next": "^6.1.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^2.10.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.7.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "start-server-and-test": "^3.0.11",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vite-plugin-checker": "^0.14.4",
    "vitest": "^4.1.10"
  }
}
